# ---- OpenClaw deployment config ----
# Copy to .env (on the server, at /opt/openclaw/.env) and fill in.
# NEVER commit the real .env (it is git-ignored).

# Model provider key. The docs default model.primary to an Anthropic Claude model.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary model OpenClaw should use. Set to whichever current Claude model you prefer.
OPENCLAW_MODEL_PRIMARY=anthropic/claude-opus-4-8

# Shared secret that protects the gateway / Control UI.
# Generate one with:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-openssl-rand-hex-32

# Container image (pin to a date tag for stability, e.g. ghcr.io/openclaw/openclaw:2026.2.26).
# Leaving it at :latest + Watchtower keeps you auto-updated; pin it to go manual.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Run the agent inside its sandbox (recommended for an internet-exposed assistant).
OPENCLAW_SANDBOX=1

# Host paths for persistent state (created by setup.sh).
OPENCLAW_CONFIG_DIR=/opt/openclaw/config
OPENCLAW_WORKSPACE_DIR=/opt/openclaw/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=/opt/openclaw/auth

# ---- Low-maintenance automation ----

# Watchtower auto-update schedule (6-field cron). Default: Sundays 04:00.
WATCHTOWER_SCHEDULE=0 0 4 * * 0

# Dead-man's-switch monitor. Create a free check at https://healthchecks.io
# (period 5m, grace 5m) and paste its ping URL here. Leave blank to disable.
# The heartbeat timer pings this every 5 min; if the host dies, you get alerted.
HEALTHCHECKS_URL=
