# ---- Email triage automation config ----
# Copy to .env (lives at /opt/claude-automations/email-triage/.env on the box).
# NEVER commit the real .env or the secrets/ dir.

# Anthropic key (required; bare mode reads this, not the keychain).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Path to the Gmail MCP config (defaults to ./mcp.gmail.json next to triage.sh).
GMAIL_MCP_CONFIG=/opt/claude-automations/email-triage/mcp.gmail.json

# Least-privilege tool allowlist — MUST match your Gmail MCP server's tool names.
# Include ONLY read + label tools. No send/delete tool may appear here.
ALLOWED_TOOLS=mcp__gmail__search_messages,mcp__gmail__read_message,mcp__gmail__modify_labels

# Where the append-only action log + last run are written.
LOG_DIR=/opt/claude-automations/email-triage/log

# Optional: push the digest to your phone (no Gmail send scope required).
# Leave blank to just rely on Gmail labels + the local action log.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
